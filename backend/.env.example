
# ---- Required ----
# Hugging Face Inference API (LLM)
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct

# Qdrant Cloud (vector database)
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# ---- Optional: server ----
# PORT=8000

# ---- Optional: advanced RAG knobs (speed vs. accuracy) ----
# Turn each retrieval stage on/off. More stages = better answers, more latency.
ENABLE_QUERY_REWRITE=true   # rewrite/translate the query with a small LLM
ENABLE_HYDE=false           # embed a hypothetical answer instead of the question
ENABLE_RERANK=true          # cross-encoder re-ranking of retrieved candidates
ENABLE_LLM_JUDGE=true       # corrective RAG: drop irrelevant context

# Retrieval / chunking tuning
RETRIEVAL_TOP_K=10          # candidates pulled before re-ranking
RERANK_TOP_N=4              # chunks kept for the final context window
CHUNK_SIZE=600
CHUNK_OVERLAP=100
RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
